# ─── CI Observer — Environment Variables ──────────────────────────────────────
#
# Copy this file to .env.local and fill in your values.
# cp .env.example .env.local

# ── Groq AI (Required for AI Pipeline Analysis feature) ──────────────────────
# Get your free API key at https://console.groq.com
# The key is ONLY used server-side and is never exposed to the browser.
GROQ_API_KEY=your_groq_api_key_here

# ─────────────────────────────────────────────────────────────────────────────
# NOTE: GitHub credentials (token, owner, repo) are NOT stored here.
# They are entered by the user through the browser and stored in localStorage.
# This keeps each user's credentials private and enables multi-project support.
# ─────────────────────────────────────────────────────────────────────────────
